APP_ENV=production
AI_PROVIDER=qwen
AI_SERVICE_TOKEN=
PUBLIC_BASE_URL=http://127.0.0.1:8000

# Qwen / DashScope
DASHSCOPE_API_KEY=
DASHSCOPE_REGION=beijing
DASHSCOPE_ASR_MODEL=fun-asr-realtime
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4
DASHSCOPE_INTENT_MODEL=qwen3.6-plus
DASHSCOPE_RECALL_MODEL=qwen3.6-plus
DASHSCOPE_TTS_MODEL=qwen3-tts-flash
DASHSCOPE_TTS_VOICE=Cherry
DASHSCOPE_TTS_LANGUAGE=Chinese

# OpenAI fallback
OPENAI_API_KEY=
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy

# Vector DB
VECTOR_DB_PROVIDER=milvus
MILVUS_URI=http://127.0.0.1:19530
MILVUS_TOKEN=
MILVUS_DATABASE=default
MILVUS_COLLECTION=memories
MILVUS_DIMENSION=1024
