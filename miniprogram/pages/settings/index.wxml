<view class="page-shell">
  <view class="card settings-card">
    <text class="title-md">长者模式</text>
    <switch checked="{{settings.seniorMode}}" data-field="seniorMode" bindchange="handleSwitchChange" color="#b64d2e" />
  </view>

  <view class="card settings-card">
    <text class="title-md">字体大小</text>
    <picker range="{{fontScaleOptions}}" value="1" bindchange="handleFontScaleChange">
      <view class="picker-value">{{settings.fontScale}}</view>
    </picker>
  </view>

  <view class="card settings-card">
    <text class="title-md">语音播报</text>
    <switch checked="{{settings.voiceReplyEnabled}}" data-field="voiceReplyEnabled" bindchange="handleSwitchChange" color="#b64d2e" />
  </view>

  <view class="card settings-card">
    <text class="title-md">播报语速</text>
    <slider min="0.6" max="1.2" step="0.05" value="{{settings.ttsSpeed}}" bindchange="handleSpeedChange" show-value activeColor="#b64d2e" />
  </view>

  <view class="card settings-card">
    <text class="title-md">每日摘要时间</text>
    <input class="digest-input" value="{{settings.dailyDigestTime}}" placeholder="19:00" bindinput="handleDigestTimeInput" />
  </view>

  <view class="card settings-card">
    <button class="save-btn" loading="{{saving}}" bindtap="handleSave">保存设置</button>
    <text class="text-sm muted">{{statusText}}</text>
  </view>
</view>
