.player-shell {
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.player-actions {
  display: flex;
  gap: 16rpx;
}

.player-btn {
  flex: 1;
  border-radius: 18rpx;
  background: #b64d2e;
  color: #fffaf2;
  font-size: 28rpx;
}

.player-btn-secondary {
  background: #e9dcc5;
  color: #5f4a31;
}
